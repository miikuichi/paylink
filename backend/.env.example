# PayLink Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit real .env file to git - this file is just a template

# ===== Spring Profile =====
SPRING_PROFILES_ACTIVE=local

# ===== Database Configuration =====
DB_HOST=your-database-host
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password_here

# ===== Security =====
# Generate a strong JWT secret (256+ chars)
# Command: openssl rand -hex 128
JWT_SECRET=your_jwt_secret_here_generate_with_openssl_rand_hex_128

# ===== CORS Configuration =====
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Logging =====
LOG_DIR=logs
LOG_LEVEL=INFO
